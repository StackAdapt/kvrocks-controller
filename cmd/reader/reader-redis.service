[Unit]
Description=Byron Test Reader
After=network-online.target syslog.target remote-fs.target nss-lookup.target sysdrun.service
Wants=network-online.target

[Service]
ExecStart=/home/ec2-user/reader -readers 2 -delay 4ms -start 1200700000 -client redis

LimitNOFILE=1048576
LimitSTACK=16777216
TimeoutSec=590
MemoryMax=95%
OOMScoreAdjust=1000

[Install]
WantedBy=multi-user.target

